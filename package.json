{
  "name": "repo-slop-analyzer",
  "version": "0.1.1",
  "type": "module",
  "description": "Deterministic CLI for finding AI-associated slop patterns in JavaScript and TypeScript repositories.",
  "bin": {
    "repo-slop-analyzer": "./bin/repo-slop-analyzer.js"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benvinegar/repo-slop-analyzer.git"
  },
  "homepage": "https://github.com/benvinegar/repo-slop-analyzer#readme",
  "bugs": {
    "url": "https://github.com/benvinegar/repo-slop-analyzer/issues"
  },
  "keywords": [
    "ai",
    "code-quality",
    "cli",
    "static-analysis",
    "typescript"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "bun run scripts/build-cli.ts",
    "scan": "bun run src/cli.ts scan .",
    "test": "bun test",
    "prepack": "bun run build",
    "benchmark:fetch": "bun run scripts/benchmark-fetch.ts",
    "benchmark:scan": "bun run scripts/benchmark-scan.ts",
    "benchmark:report": "bun run scripts/benchmark-report.ts",
    "benchmark:update": "bun run benchmark:fetch && bun run benchmark:scan && bun run benchmark:report"
  },
  "dependencies": {
    "typescript": "^5.8.3"
  }
}
