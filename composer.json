{
    "name": "voku/slop-scan",
    "description": "Deterministic PHP CLI for explainable slop heuristics in PHP repositories.",
    "type": "project",
    "require": {
        "php": "^8.3",
        "symfony/console": "^7.4",
        "voku/simple-php-code-parser": "^0.21.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5"
    },
    "license": "MIT",
    "authors": [
        {
            "name": "voku",
            "email": "opensource@voku.dev"
        }
    ],
    "autoload": {
        "psr-4": {
            "SlopScan\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SlopScan\\Tests\\": "tests/"
        }
    },
    "bin": [
        "bin/slop-scan.php"
    ],
    "scripts": {
        "format:check": "find src tests bin build -name '*.php' -print0 | xargs -0 -n1 php -l",
        "lint": "find src tests bin build -name '*.php' -print0 | xargs -0 -n1 php -l",
        "analyse": "find src tests bin build -name '*.php' -print0 | xargs -0 -n1 php -l",
        "phar:build": "php -d phar.readonly=0 build/build-phar.php",
        "test": "phpunit tests",
        "test:php": "phpunit tests",
        "scan:self": "php bin/slop-scan.php scan src --json",
        "scan:php:self": "php bin/slop-scan.php scan src --json"
    }
}
