{
  "ignores": [
    "**/vendor/**",
    "**/.git/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.generated.*"
  ],
  "rules": {
    "php.directory-fanout-hotspot": {
      "options": {
        "fileCount": 16
      }
    }
  },
  "overrides": [
    {
      "path": "src/Rule",
      "rules": {
        "php.directory-fanout-hotspot": {
          "options": {
            "fileCount": 23
          }
        }
      }
    },
    {
      "path": "src/Fact/PhpFacts.php",
      "rules": {
        "php.catch-default-fallbacks": {
          "enabled": false
        }
      }
    }
  ]
}
