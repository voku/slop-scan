{
  "ignores": [
    "**/vendor/**",
    "**/.git/**",
    "**/build/**",
    "**/coverage/**",
    "**/*.generated.*"
  ],
  "rules": {
    "php.directory-fanout-hotspot": {
      "options": {
        "fileCount": 16
      }
    }
  },
  "overrides": [
    {
      "path": "src/Rule",
      "rules": {
            "php.directory-fanout-hotspot": {
              "options": {
                "fileCount": 25
              }
            }
          }
    },
    {
      "path": "src/Fact/PhpFacts.php",
      "rules": {
        "php.catch-default-fallbacks": {
          "enabled": false
        }
      }
    },
    {
      "path": "tests/**",
      "rules": {
        "php.magic-numbers": {
          "enabled": false
        }
      }
    }
  ]
}
